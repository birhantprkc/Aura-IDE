{
  "name": "Web Research",
  "description": "Receives a research goal, extracts a query, performs live web research for current-info questions, and returns a structured research receipt with sourced evidence.",
  "instructions": "This drone receives a goal string from Aura, extracts a research query from it, and performs live web research to answer current-info questions (like schedules, recent events, versions). It returns a structured receipt with sources, evidence, gaps, and confidence.\n\nGoal parsing: The drone reads one JSON object from stdin. It supports:\n- plain goal text as the query\n- optional `query:` line\n\nIf `query:` exists, use that as the query. Otherwise use the non-empty goal text.",
  "kind": "command",
  "write_policy": "read_only",
  "scope": "global",
  "runtime": "python",
  "entrypoint": {
    "kind": "command",
    "command": ["python", "main.py"],
    "protocol": "json-stdio"
  },
  "budget": {
    "timeout_seconds": 120
  },
  "manifest_version": "1",
  "permissions": {
    "browser_profile": "research",
    "visible": false,
    "live_browser_enabled": true
  },
  "output_contract": {
    "oneOf": [
      {
        "title": "Success",
        "type": "object",
        "properties": {
          "ok": { "const": true },
          "summary": { "type": "string" },
          "query": { "type": "string" },
          "answer": { "type": "string" },
          "verified_facts": { "type": "array", "items": { "type": "string" } },
          "sources": { "type": "array", "items": { "type": "object" } },
          "evidence": { "type": "array", "items": { "type": "object" } },
          "gaps": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low", "none"] },
          "trace": { "type": "array", "items": { "type": "object" } },
          "route_used": { "type": "object" }
        },
        "required": ["ok", "summary", "query", "answer", "verified_facts", "sources", "evidence", "gaps", "confidence", "trace", "route_used"]
      },
      {
        "title": "Failure",
        "type": "object",
        "properties": {
          "ok": { "const": false },
          "error": { "type": "string" },
          "summary": { "type": "string" }
        },
        "required": ["ok", "error", "summary"]
      }
    ]
  }
}
